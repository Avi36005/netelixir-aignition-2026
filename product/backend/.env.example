# ROAScast product backend — optional LLM keys.
# WITHOUT these, /explain returns a grounded deterministic narrative (works
# fully offline). WITH a key, it uses Gemini Flash, then Groq as a fallback.
# These belong to the PRODUCT layer only — never used by the scored run.sh.

# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-1.5-flash

# GROQ_API_KEY=your-groq-key
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: point at a different committed model pickle.
# ROASCAST_MODEL_PATH=../../pickle/model.pkl
